[Unit]
Description=Fake HTTPS Panel
After=network.target

[Service]
User=honeypot
Group=honeypot
WorkingDirectory=/opt/honeypot-demo/fakepanel
Environment="PATH=/opt/honeypot-demo/fakepanel/venv/bin"
ExecStart=/opt/honeypot-demo/fakepanel/venv/bin/gunicorn -w 2 -b 0.0.0.0:8443 app:app
Restart=always
RestartSec=5

[Install]
WantedBy=multi-user.target